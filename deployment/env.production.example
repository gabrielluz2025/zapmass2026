NODE_ENV=production
PORT=3001

# Obrigatorio em producao: mesma origem que o usuario abre no navegador (sem barra no fim).
# Inclua porta se acessar direto na porta do Node; com Nginx na 443 use https://seu-dominio.com
ALLOWED_ORIGINS=http://SEU_IP:3001,https://seu-dominio.com

# Docker: copie este arquivo ou .env.example para ".env" na raiz e use "docker compose up -d --build".
# HOST_PORT=3001

# Opcional: dados e sessao WhatsApp fora do repo
# DATA_DIR=/opt/zapmass-sender/data
# AUTH_DIR=/opt/zapmass-sender/data/.wwebjs_auth

# Bundle WhatsApp Web — deployment/wwebjs-default-bundle.env + https://github.com/wppconnect-team/wa-version/tree/main/html
WWEBJS_WEB_VERSION_URL=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1034300341-alpha.html

# Firebase Admin (webhooks de assinatura / painel admin server-side)
# FIREBASE_SERVICE_ACCOUNT_PATH=/opt/zapmass-sender/secrets/firebase-admin.json

# Backup agendado (opcional)
# BACKUP_API_KEY=gere-uma-chave-longa
# BACKUP_ON_START=true
# BACKUP_INTERVAL_MINUTES=1440
