# Exemplo: Nginx como proxy reverso para ZapMass (Docker na porta 3001).
# Copie para /etc/nginx/sites-available/zap-mass e ajuste server_name.
#
# Depois:
#   sudo ln -sf /etc/nginx/sites-available/zap-mass /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d zap-mass.com -d www.zap-mass.com
#
# No /opt/zapmass/.env use a MESMA origem HTTPS:
#   ALLOWED_ORIGINS=https://zap-mass.com,https://www.zap-mass.com
#   docker compose restart

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name zap-mass.com www.zap-mass.com;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
