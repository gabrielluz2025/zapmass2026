{
  "name": "zapmass-sender",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev:kill\" \"npm run client:dev:kill\"",
    "dev:full": "concurrently \"npm run server:dev:kill\" \"npm run client:dev:kill\"",
    "build": "vite build && npm run server:build",
    "preview": "vite preview",
    "client:dev:kill": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 8000 && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/wait-api-health.ps1 -TimeoutSec 120 && vite --host 0.0.0.0 --port 8000 --strictPort",
    "server:dev": "tsx watch server/server.ts",
    "worker:dev": "cross-env SESSION_PROCESS_MODE=worker tsx watch server/waWorker.ts",
    "dev:api+worker": "concurrently -n api,wa -c blue,green \"npm run server:dev:kill\" \"npm run worker:dev\"",
    "server:dev:kill": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3001 && tsx watch server/server.ts",
    "server:build": "echo 'Backend build not required for tsx/ts-node in this setup, ensuring dist exists'",
    "start": "cross-env NODE_ENV=production tsx server/server.ts",
    "backup": "tsx server/backupRunner.ts",
    "migrate:legacy:user": "tsx server/migrateLegacyToUser.ts",
    "sanitize:tenant:campaigns": "tsx server/sanitizeTenantCampaigns.ts",
    "version:show": "node -e \"const fs=require('fs');console.log(fs.readFileSync('VERSION','utf8').trim())\"",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f"
    ,"session:resilience-check":"tsx scripts/session-resilience-check.ts"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "@wppconnect-team/wppconnect": "^1.38.0",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase": "^10.8.0",
    "firebase-admin": "^13.8.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.344.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^22.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "tsx": "^4.7.1",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
