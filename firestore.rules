rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Membro da equipa (userWorkspaceLinks): acesso aos dados do dono (mesmo uid em users/{dono}/...)
    function workspaceLinkOwnerUid() {
      return get(/databases/$(database)/documents/userWorkspaceLinks/$(request.auth.uid)).data.ownerUid;
    }
    function isTeamMemberOf(targetUserPathUid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/userWorkspaceLinks/$(request.auth.uid))
        && workspaceLinkOwnerUid() == targetUserPathUid;
    }
    function canAccessUserSubtree(targetUserPathUid) {
      return request.auth != null && (request.auth.uid == targetUserPathUid || isTeamMemberOf(targetUserPathUid));
    }
    
    // --- Regras do Sistema ZapMass ---
    // Permite leitura e escrita livre para funcionamento sem login
    // IMPORTANTE: Em produção com dados reais, implemente Firebase Auth.
    
    // Coleções legadas (antes de users/{uid}/...). Leitura para o app mesclar na UI;
    // delete permite limpar duplicata após migração; create/update desligados (novos dados em users/{uid}).
    match /contacts/{docId} {
      allow read, delete: if request.auth != null;
      allow create, update: if false;
    }

    match /contact_lists/{docId} {
      allow read, delete: if request.auth != null;
      allow create, update: if false;
    }

    match /campaigns/{docId} {
      allow read, delete: if request.auth != null;
      allow create, update: if false;
    }

    // Plano B: isolamento por usuário (cada cliente só enxerga seus próprios dados)
    match /users/{uid}/contacts/{docId} {
      allow read, write: if canAccessUserSubtree(uid);
    }

    match /users/{uid}/contact_lists/{docId} {
      allow read, write: if canAccessUserSubtree(uid);
    }

    match /users/{uid}/campaigns/{campaignId} {
      allow read, write: if canAccessUserSubtree(uid);
      match /logs/{logId} {
        allow read, write: if canAccessUserSubtree(uid);
      }
    }

    /** Credenciais de funcionários (nome de usuário + senha) — só servidor (Firebase Admin SDK). */
    match /users/{uid}/staffPasswordUsers/{docId} {
      allow read, write: if false;
    }

    match /users/{uid}/suggestions/{docId} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }

    match /users/{uid}/notifications/{docId} {
      allow read, update, delete: if canAccessUserSubtree(uid);
      allow create: if false;
    }

    /** Vinculo funcionario ↔ dono (leitura propria ou do dono). Escrita via Firebase Admin apenas. */
    match /userWorkspaceLinks/{staffUid} {
      allow read: if request.auth != null &&
        (request.auth.uid == staffUid || resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    // --- Regras Legadas / ZapFlow ---
    // Proteção por ID de usuário e App ID
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /system_configs/{config} {
       allow read: if request.auth != null;
    }

    // Assinatura (lido pelo app; escrita apenas via Firebase Admin nos webhooks do servidor)
    match /userSubscriptions/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isTeamMemberOf(uid));
      allow write: if false;
    }

    // Config publica do produto (precos de marketing, textos do teste). Escrita apenas via Admin SDK (API servidor).
    match /appConfig/{docId} {
      allow read: if docId == 'global';
      allow write: if false;
    }
  }
}