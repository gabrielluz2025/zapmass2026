NODE_ENV=production
PORT=3001

# URL exata no navegador (sem barra no fim). Várias origens: separadas por vírgula.
ALLOWED_ORIGINS=http://SEU_IP_OU_DOMINIO:3001

# Porta publicada no host (docker-compose)
# HOST_PORT=3001

# Bundle HTML do WhatsApp Web (whatsapp-web.js) — reduz falhas getChat/LID/markedUnread.
# Mantido em sync em deployment/wwebjs-default-bundle.env
# Outros snapshots: https://github.com/wppconnect-team/wa-version/tree/main/html
WWEBJS_WEB_VERSION_URL=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1034300341-alpha.html
