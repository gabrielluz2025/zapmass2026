# Copie as variaveis necessarias para o .env do servidor (nao commitar segredos).

# --- Firebase Admin (obrigatorio para webhooks gravarem no Firestore) ---
# Caminho absoluto para o JSON da conta de servico (GCP > IAM > conta de servico > chave JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=
# OU coloque o JSON inteiro em uma linha (cuidado com aspas em producao)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Mercado Pago (consulta API ao receber webhook + checkout preapproval) ---
MERCADOPAGO_ACCESS_TOKEN=
# URL para onde o MP redireciona apos o fluxo (ex.: front em producao ou localhost)
MERCADOPAGO_BACK_URL=http://localhost:8000
# Valores em BRL usados em POST /api/billing/mercadopago/start (preapproval)
MERCADOPAGO_PRICE_MONTHLY=49.9
MERCADOPAGO_PRICE_ANNUAL=479.9

# --- Infinite Pay (checkout publico + webhook opcional) ---
# InfiniteTag da loja (sem @), obrigatorio para POST /api/billing/infinitepay/start
INFINITEPAY_HANDLE=
# URL publica do webhook (ex.: https://seu-dominio.com/api/webhooks/infinitepay) — repasse ao criar o link
INFINITEPAY_WEBHOOK_URL=
# Apos pagamento, redireciona o cliente (opcional; default MERCADOPAGO_BACK_URL ou localhost:8000)
INFINITEPAY_REDIRECT_URL=http://localhost:8000
# Precos em centavos (opcional; se vazio, usa MERCADOPAGO_PRICE_* em reais convertidos)
# INFINITEPAY_PRICE_MONTHLY_CENTS=4990
# INFINITEPAY_PRICE_ANNUAL_CENTS=47990
# Se INFINITEPAY_WEBHOOK_SECRET estiver definido, o POST do webhook deve enviar o mesmo valor no header x-infinitepay-secret
INFINITEPAY_WEBHOOK_SECRET=

# --- Admin: gravacao de appConfig/global (PUT /api/admin/app-config) ---
# Lista de e-mails (minusculo) separados por virgula. Alternativa: custom claim admin=true no token Firebase.
ADMIN_EMAILS=

# --- Front (Vite): menu "Criador" visivel para estes e-mails (deve coincidir com ADMIN_EMAILS para salvar) ---
# VITE_ADMIN_EMAILS=voce@dominio.com,outro@dominio.com

# --- Estudio do criador (somente dev): menu extra + area interna. Use o BAT scripts/iniciar-estudio-criador.bat ---
# VITE_CREATOR_STUDIO=true

# --- Front (Vite): textos de marketing no modal Pro (opcional) ---
# VITE_MARKETING_PRICE_MONTHLY=R$ 49,90 / mes
# VITE_MARKETING_PRICE_ANNUAL=R$ 479,90 / ano

# --- Front (Vite): cobranca / teste ---
# Com true: exige doc userSubscriptions; sem doc mostra onboarding; teste 1h ou Pro liberam acesso.
# Com false: app sempre liberado (desenvolvimento).
# VITE_ENFORCE_SUBSCRIPTION=true

# --- Servidor: teste gratuito 1h (POST /api/billing/trial/start, Firebase Admin obrigatorio) ---
# Nao precisa de variavel extra; o mesmo FIREBASE_SERVICE_ACCOUNT_* grava trialEndsAt e freeTrialUsed.
